# Copy to .env and fill in values.
# Required for generate + security-assess (Gemini).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_JUDGE=

# Optional: default target when using the web UI modal skip
# TARGET=localhost:3000
# COMPONENT=main

# Optional: AIRTA Systems export (Export tab)
# AIRTASYSTEMS_HOST=https://dashboard.airtasystems.com
# AIRTASYSTEMS_API_KEY= get from airta systems dashboard
# AIRTASYSTEMS_PROGRAM_ID= get from airta systems dashboard
# AIRTASYSTEMS_EXPORT_SCHEMA=security   # security (default) | legacy
# AIRTASYSTEMS_IMPORT_PATH=            # override path, e.g. /api/v2/imported-reports/company
# AIRTASYSTEMS_DEFAULT_SEVERITY=indeterminate
# AIRTASYSTEMS_EXPORT_BATCH_SIZE=25    # results per POST (default 25; was 2500)
# AIRTASYSTEMS_EXPORT_DELAY_SECONDS=2  # pause between batches and multi-report exports
# AIRTASYSTEMS_EXPORT_MAX_RETRIES=6    # retries on 429 / rate limit
# AIRTASYSTEMS_EXPORT_RETRY_BASE_SECONDS=5

# Optional: assessment concurrency
# SECURITY_ASSESS_CONCURRENCY=1

# Optional: multimodal payload output directory (default: payloads/generate/)
# PAYLOADS_OUTPUT_DIR=payloads/generate
